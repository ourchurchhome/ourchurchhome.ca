---
/**
 * src/cms/layouts/CmsShell.astro
 *
 * Server-rendered layout for all CMS pages. Loads the CMS config,
 * resolves collections, and mounts the sidebar React component.
 * Page-specific content is injected via <slot />.
 */
export const prerender = false;

import '../../styles/global.css';
import cmsConfig from '../../../cms.config';
import { resolveCollections } from '../lib/resolve-config';
import CmsSidebar, { CmsNavToggle } from '../components/CmsSidebar';

const session = Astro.locals.session;
if (!session) return Astro.redirect('/cms/login');
const collections = resolveCollections(cmsConfig);

const sidebarCollections = collections.map(({ name, label, singleton, icon }) => ({
  name,
  label,
  singleton,
  icon,
}));

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CMS — OurChurchHome</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100">
    <CmsSidebar
      client:load
      collections={sidebarCollections}
      user={{
        name: session.name,
        username: session.username,
        avatarUrl: session.avatarUrl,
      }}
      currentPath={currentPath}
    />

    <main class="min-h-screen lg:pl-64">
      <div class="lg:hidden flex items-center px-4 py-3 border-b border-gray-800">
        <CmsNavToggle client:load />
      </div>
      <slot />
    </main>
  </body>
</html>

