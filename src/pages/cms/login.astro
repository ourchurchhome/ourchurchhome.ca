---
export const prerender = false;

import { GitHub, generateState } from 'arctic';
import { getSession } from '../../cms/lib/session';
import '../../styles/global.css';

// Already authenticated → go straight to the dashboard
const session = getSession(Astro.request);
if (session) return Astro.redirect('/cms');

const error = Astro.url.searchParams.get('error');

// POST: build the GitHub OAuth authorization URL and redirect
if (Astro.request.method === 'POST') {
  const github = new GitHub(
    import.meta.env.GITHUB_CLIENT_ID,
    import.meta.env.GITHUB_CLIENT_SECRET,
    `${Astro.url.origin}/cms/auth/callback`
  );

  const state = generateState();
  const authUrl = github.createAuthorizationURL(state, ['read:user', 'repo']);

  const stateCookie = [
    `cms_oauth_state=${state}`,
    'HttpOnly',
    'SameSite=Lax',
    'Path=/cms/auth',
    'Max-Age=600',
  ].join('; ');

  return new Response(null, {
    status: 302,
    headers: {
      Location: authUrl.toString(),
      'Set-Cookie': stateCookie,
    },
  });
}

---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — OurChurchHome CMS</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="h-full bg-gray-950 text-gray-100 flex items-center justify-center p-6">
    <div class="w-full max-w-sm">

      <!-- Logo / title -->
      <div class="text-center mb-8">
        <p class="text-xs font-mono uppercase tracking-widest text-gray-500 mb-1">OurChurchHome</p>
        <h1 class="text-2xl font-semibold text-white">CMS</h1>
        <p class="mt-3 text-sm text-gray-400">
          Sign in with your GitHub account to manage site content.<br />
          You must be a repository collaborator to gain access.
        </p>
      </div>

      <!-- Error banner -->
      {error === 'not_collaborator' && (
        <div class="mb-5 px-4 py-3 rounded-lg bg-red-900/40 border border-red-700 text-red-300 text-sm text-center">
          Your GitHub account is not a collaborator on this repository.<br />
          Contact the site administrator to request access.
        </div>
      )}

      <!-- Login form — POST triggers the OAuth redirect -->
      <form method="POST">
        <button
          type="submit"
          class="w-full flex items-center justify-center gap-3 px-5 py-3 rounded-lg bg-white hover:bg-gray-100 active:bg-gray-200 text-gray-900 font-medium text-sm transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
        >
          <!-- GitHub mark SVG -->
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.31.465-2.381 1.235-3.221-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.51 11.51 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.911 1.23 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.814 1.102.814 2.222 0 1.606-.015 2.898-.015 3.293 0 .319.216.694.825.576C20.565 21.796 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
          </svg>
          Sign in with GitHub
        </button>
      </form>

    </div>
  </body>
</html>

