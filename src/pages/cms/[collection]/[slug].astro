---
export const prerender = false;

import CmsShell from '../../../cms/layouts/CmsShell.astro';
import { EditorLayout } from '../../../cms/components/EditorLayout';
import cmsConfig from '../../../../cms.config';
import { resolveCollections } from '../../../cms/lib/resolve-config';
import { getFile, putFile, deleteFile } from '../../../cms/lib/github-api';
import { parseMarkdown, parseJson, serializeMarkdown, serializeJson, itemPath } from '../../../cms/lib/content';
import type { ResolvedField } from '../../../cms/config';

const { collection: collectionName, slug } = Astro.params;
const collections = resolveCollections(cmsConfig);
const collection = collections.find((c) => c.name === collectionName);
if (!collection) return new Response('Collection not found', { status: 404 });

const session = Astro.locals.session;
if (!session) return Astro.redirect('/cms/login');

const filePath = itemPath(collectionName!, slug!);

// ── Coerce a formData string value to the right JS type ─────────────────────
function coerce(raw: string | null, field: ResolvedField): unknown {
  if (raw === null || raw === '') return undefined;
  switch (field.type) {
    case 'boolean': return raw === 'true';
    case 'number':  return Number(raw);
    case 'date':    return raw; // keep as ISO string; Zod will coerce
    case 'array':
    case 'object':  try { return JSON.parse(raw); } catch { return raw; }
    default:        return raw;
  }
}

// ── POST: save ───────────────────────────────────────────────────────────────
let saveError: string | null = null;
const isFetch = Astro.request.headers.get('X-CMS-Fetch') === '1';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const sha  = form.get('__sha') as string;
    const body = (form.get('body') as string | null) ?? '';

    // Slug rename: client sends __newSlug; normalize it the same way new.astro does
    const rawNewSlug = (form.get('__newSlug') as string | null)?.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    const newSlug = rawNewSlug || slug!;
    const isRename = collection.allowRename && newSlug !== slug;
    const newFilePath = isRename ? itemPath(collectionName!, newSlug) : filePath;

    const frontmatter: Record<string, unknown> = {};
    for (const field of collection.fields) {
      const raw = form.get(field.key) as string | null;
      const val = coerce(raw, field);
      if (val !== undefined) frontmatter[field.key] = val;
    }

    let fileContent: string;
    if (collection.fileExtension === 'md') {
      fileContent = serializeMarkdown(frontmatter, body);
    } else {
      fileContent = serializeJson(frontmatter);
    }

    // Write the file at the (possibly new) path, then delete the old one if renamed
    const { sha: newSha } = await putFile(session.token, newFilePath, fileContent, `cms: ${isRename ? `rename ${slug} → ${newSlug}` : `update ${collectionName}/${slug}`}`, isRename ? undefined : sha);
    if (isRename) {
      await deleteFile(session.token, filePath, sha, `cms: remove old ${collectionName}/${slug} after rename`);
    }

    const redirectUrl = isRename ? `/cms/${collectionName}/${newSlug}` : undefined;

    if (isFetch) {
      return new Response(JSON.stringify({ sha: newSha, ...(redirectUrl ? { redirectUrl } : {}) }), {
        headers: { 'Content-Type': 'application/json' },
      });
    }
    if (redirectUrl) return Astro.redirect(redirectUrl);
  } catch (e) {
    if (isFetch) {
      return new Response(JSON.stringify({ error: e instanceof Error ? e.message : 'Save failed' }), {
        status: 500,
        headers: { 'Content-Type': 'application/json' },
      });
    }
    saveError = e instanceof Error ? e.message : 'Save failed';
  }
}

// ── GET: load file ───────────────────────────────────────────────────────────
let parsed: { frontmatter: Record<string, unknown>; body: string; sha: string } | null = null;
let loadError: string | null = null;

try {
  const { content, sha } = await getFile(session.token, filePath);
  parsed = collection.fileExtension === 'md'
    ? parseMarkdown(content, sha)
    : parseJson(content, sha);
} catch (e) {
  loadError = e instanceof Error ? e.message : 'Failed to load file';
}
---

<CmsShell>
  {loadError && (
    <div class="h-full flex flex-col">
      <div class="shrink-0 flex items-center gap-3 px-5 h-[60px] border-b border-gray-800">
        <a href={`/cms/${collectionName}`} class="text-gray-400 hover:text-white text-sm transition-colors">← {collection.label}</a>
        <span class="text-gray-600">/</span>
        <h1 class="text-sm font-semibold text-white font-mono">{slug}</h1>
      </div>
      <div class="p-6">
        <div class="p-3 bg-red-900/50 border border-red-700 rounded text-red-300 text-sm">{loadError}</div>
      </div>
    </div>
  )}

  {parsed && (
    <div class="h-full">
      <EditorLayout
        client:load
        hasBody={collection.fileExtension === 'md'}
        fields={collection.fields}
        initialValues={parsed.frontmatter}
        initialBody={parsed.body}
        collectionLabel={collection.label}
        collectionHref={`/cms/${collectionName}`}
        slug={slug!}
        initialSha={parsed.sha}
        allowSlugRename={collection.allowRename}
      />
    </div>
  )}
</CmsShell>

