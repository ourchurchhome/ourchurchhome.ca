---
export const prerender = false;

import CmsShell from '../../../cms/layouts/CmsShell.astro';
import { FieldsPane } from '../../../cms/components/FieldsPane';
import { VisualEditor } from '../../../cms/components/VisualEditor';
import cmsConfig from '../../../../cms.config';
import { resolveCollections } from '../../../cms/lib/resolve-config';
import { getFile, putFile } from '../../../cms/lib/github-api';
import { parseMarkdown, parseJson, serializeMarkdown, serializeJson, itemPath } from '../../../cms/lib/content';
import type { ResolvedField } from '../../../cms/config';

const { collection: collectionName, slug } = Astro.params;
const collections = resolveCollections(cmsConfig);
const collection = collections.find((c) => c.name === collectionName);
if (!collection) return new Response('Collection not found', { status: 404 });

const session = Astro.locals.session;
if (!session) return Astro.redirect('/cms/login');

const filePath = itemPath(collectionName!, slug!);

// ── Coerce a formData string value to the right JS type ─────────────────────
function coerce(raw: string | null, field: ResolvedField): unknown {
  if (raw === null || raw === '') return undefined;
  switch (field.type) {
    case 'boolean': return raw === 'true';
    case 'number':  return Number(raw);
    case 'date':    return raw; // keep as ISO string; Zod will coerce
    case 'array':
    case 'object':  try { return JSON.parse(raw); } catch { return raw; }
    default:        return raw;
  }
}

// ── POST: save ───────────────────────────────────────────────────────────────
let saveError: string | null = null;
let saveSuccess = false;

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const sha  = form.get('__sha') as string;
    const body = (form.get('body') as string | null) ?? '';

    const frontmatter: Record<string, unknown> = {};
    for (const field of collection.fields) {
      const raw = form.get(field.key) as string | null;
      const val = coerce(raw, field);
      if (val !== undefined) frontmatter[field.key] = val;
    }

    let fileContent: string;
    if (collection.fileExtension === 'md') {
      fileContent = serializeMarkdown(frontmatter, body);
    } else {
      fileContent = serializeJson(frontmatter);
    }

    await putFile(session.token, filePath, fileContent, `cms: update ${collectionName}/${slug}`, sha);
    saveSuccess = true;
  } catch (e) {
    saveError = e instanceof Error ? e.message : 'Save failed';
  }
}

// ── GET: load file ───────────────────────────────────────────────────────────
let parsed: { frontmatter: Record<string, unknown>; body: string; sha: string } | null = null;
let loadError: string | null = null;

try {
  const { content, sha } = await getFile(session.token, filePath);
  parsed = collection.fileExtension === 'md'
    ? parseMarkdown(content, sha)
    : parseJson(content, sha);
} catch (e) {
  loadError = e instanceof Error ? e.message : 'Failed to load file';
}
---

<CmsShell>
  <div class="p-8 max-w-3xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
      <a href={`/cms/${collectionName}`} class="text-gray-400 hover:text-white text-sm transition-colors">← {collection.label}</a>
      <span class="text-gray-600">/</span>
      <h1 class="text-xl font-semibold text-white font-mono">{slug}</h1>
    </div>

    {loadError && <div class="mb-6 p-3 bg-red-900/50 border border-red-700 rounded text-red-300 text-sm">{loadError}</div>}
    {saveError && <div class="mb-6 p-3 bg-red-900/50 border border-red-700 rounded text-red-300 text-sm">{saveError}</div>}
    {saveSuccess && <div class="mb-6 p-3 bg-green-900/50 border border-green-700 rounded text-green-300 text-sm">Saved successfully.</div>}

    {parsed && (
      <form method="POST">
        <input type="hidden" name="__sha" value={parsed.sha} />

        {collection.fields.length > 0 && (
          <section class="mb-8 bg-gray-800 rounded-lg p-5 border border-gray-700">
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Fields</h2>
            <FieldsPane
              client:load
              fields={collection.fields}
              initialValues={parsed.frontmatter}
            />
          </section>
        )}

        {collection.fileExtension === 'md' && (
          <section class="mb-8">
            <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Content</h2>
            <VisualEditor client:load initialValue={parsed.body} name="body" />
          </section>
        )}

        <div class="flex justify-end gap-3">
          <a href={`/cms/${collectionName}`} class="px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors">Cancel</a>
          <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-md transition-colors">
            Save changes
          </button>
        </div>
      </form>
    )}
  </div>
</CmsShell>

