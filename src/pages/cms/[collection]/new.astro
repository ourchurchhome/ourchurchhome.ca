---
export const prerender = false;

import CmsShell from '../../../cms/layouts/CmsShell.astro';
import { EditorLayout } from '../../../cms/components/EditorLayout';
import cmsConfig from '../../../../cms.config';
import { resolveCollections } from '../../../cms/lib/resolve-config';
import { createPersistenceService } from '../../../cms/lib/persistence';
import { serializeMarkdown, serializeJson, itemPath } from '../../../cms/lib/content';
import type { ResolvedField } from '../../../cms/config';

const { collection: collectionName } = Astro.params;
const collections = resolveCollections(cmsConfig);
const collection = collections.find((c) => c.name === collectionName);
if (!collection) return new Response('Collection not found', { status: 404 });
if (!collection.allowCreate) return new Response('Create not allowed', { status: 403 });

const session = Astro.locals.session;
if (!session) return Astro.redirect('/cms/login');

// ── Coerce a formData string value to the right JS type ─────────────────────
function coerce(raw: string | null, field: ResolvedField): unknown {
  if (raw === null || raw === '') return undefined;
  switch (field.type) {
    case 'boolean': return raw === 'true';
    case 'number':  return Number(raw);
    case 'date':    return raw;
    case 'array':
    case 'object':  try { return JSON.parse(raw); } catch { return raw; }
    default:        return raw;
  }
}

const persistence = createPersistenceService(session.token);

// ── POST: create ─────────────────────────────────────────────────────────────
const isFetch = Astro.request.headers.get('X-CMS-Fetch') === '1';
let createError: string | null = null;

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const newSlug = (form.get('__slug') as string).trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    if (!newSlug) throw new Error('Slug is required');

    const body = (form.get('body') as string | null) ?? '';

    const frontmatter: Record<string, unknown> = {};
    for (const field of collection.fields) {
      const raw = form.get(field.key) as string | null;
      const val = coerce(raw, field);
      if (val !== undefined) frontmatter[field.key] = val;
    }

    let fileContent: string;
    if (collection.fileExtension === 'md') {
      fileContent = serializeMarkdown(frontmatter, body);
    } else {
      fileContent = serializeJson(frontmatter);
    }

    const filePath = itemPath(collectionName!, newSlug);
    await persistence.writeItem(filePath, fileContent, `cms: create ${collectionName}/${newSlug}`);

    const redirectUrl = `/cms/${collectionName}/${newSlug}`;
    if (isFetch) {
      return new Response(JSON.stringify({ redirectUrl }), {
        headers: { 'Content-Type': 'application/json' },
      });
    }
    return Astro.redirect(redirectUrl);
  } catch (e) {
    if (isFetch) {
      return new Response(JSON.stringify({ error: e instanceof Error ? e.message : 'Create failed' }), {
        status: 500,
        headers: { 'Content-Type': 'application/json' },
      });
    }
    createError = e instanceof Error ? e.message : 'Create failed';
  }
}
---

<CmsShell>
  <div class="h-full">
    <EditorLayout
      client:load
      hasBody={collection.fileExtension === 'md'}
      fields={collection.fields}
      initialValues={{}}
      initialBody=""
      collectionLabel={collection.label}
      collectionHref={`/cms/${collectionName}`}
      slug="new"
      initialSha=""
      isNew={true}
    />
  </div>
</CmsShell>

