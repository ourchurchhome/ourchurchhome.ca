---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const churches = await getCollection('churches');
const articles = await getCollection('articles', ({ data }) => !data.draft);

const bannerEntries = await getCollection('banner');
const bannerEntry = bannerEntries[0];
const bannerEnabled = bannerEntry?.data.enabled ?? false;
const bannerLink = bannerEntry?.data.link ?? null;
const { Content: BannerContent } = bannerEntry ? await render(bannerEntry) : { Content: null };
const recentArticles = articles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home" description="Mount Stewart, Morell, St. Peters Bay Pastoral Charge — ourchurchhome.ca">

  <!-- Banner -->
  {bannerEnabled && BannerContent && (
    bannerLink ? (
      <a
        href={bannerLink}
        class="group flex items-center justify-center gap-2 bg-secondary text-on-secondary px-6 py-3 text-center text-sm font-medium leading-snug hover:bg-secondary-container transition-colors duration-200 [&_p]:inline [&_strong]:font-bold"
      >
        <BannerContent />
        <span class="material-symbols-outlined text-base shrink-0 transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">arrow_forward</span>
      </a>
    ) : (
      <div class="flex items-center justify-center bg-secondary text-on-secondary px-6 py-3 text-center text-sm font-medium leading-snug [&_p]:inline [&_strong]:font-bold">
        <BannerContent />
      </div>
    )
  )}

  <!-- Hero -->
  <section class="relative flex items-center overflow-hidden" style="min-height: 560px;">
    <img
      src="https://images.unsplash.com/photo-1438032005730-c779502df39b?auto=format&fit=crop&w=1600&q=80"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 hero-gradient opacity-85"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full py-24">
      <div class="max-w-2xl">
        <h1 class="font-headline text-5xl md:text-6xl text-on-primary font-bold mb-6 leading-tight tracking-tight">
          Welcome Home<br /><span class="text-tertiary-fixed-dim">to Community</span>
        </h1>
        <p class="text-on-primary/85 text-lg md:text-xl mb-10 font-light leading-relaxed">
          A place of grace, heritage, and hope across Mount Stewart, Morell, and St. Peters Bay.
          Join us as we journey together in faith.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/churches/morell" class="bg-secondary text-on-primary px-8 py-3 rounded-xl font-semibold text-base shadow-lg hover:-translate-y-0.5 transition-all duration-200 active:scale-95">
            Visit a Church
          </a>
          <a href="/articles" class="bg-white/10 border border-white/25 text-on-primary px-8 py-3 rounded-xl font-semibold text-base hover:bg-white/20 transition-all duration-200">
            News &amp; Updates
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent News -->
  {recentArticles.length > 0 && (
    <section class="py-20" aria-labelledby="news-heading">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-baseline justify-between mb-10">
          <div>
            <span class="text-secondary font-label font-bold tracking-[0.3em] uppercase block mb-2 text-sm">Latest</span>
            <h2 id="news-heading" class="font-headline text-3xl font-bold text-primary">News &amp; Updates</h2>
          </div>
          <a href="/articles" class="text-sm font-semibold text-secondary hover:underline">View all →</a>
        </div>
        <ul class="grid gap-6 sm:grid-cols-3">
          {recentArticles.map((article) => (
            <li>
              <a href={`/articles/${article.id}`} class="group block h-full bg-surface-container-lowest border border-outline-variant rounded-xl p-6 hover:border-secondary hover:shadow-sm transition-all duration-200">
                <span class="inline-block text-xs font-label font-semibold uppercase tracking-wider text-on-secondary bg-secondary px-2 py-0.5 rounded mb-3 capitalize">
                  {article.data.category}
                </span>
                <h3 class="font-headline font-bold text-primary group-hover:text-secondary mb-2 transition-colors leading-snug">
                  {article.data.title}
                </h3>
                <p class="text-xs text-outline mb-3">
                  {article.data.date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                </p>
                {article.data.description && (
                  <p class="text-sm text-on-surface-variant leading-relaxed">{article.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- Mission -->
  <section class="py-20 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-14 items-center">
        <div>
          <h2 class="font-headline text-primary text-4xl font-bold mb-6">Our Shared Vision</h2>
          <p class="text-on-surface-variant text-lg leading-relaxed mb-5">
            We are a multi-point charge dedicated to fostering a spirit of inclusivity, compassion, and spiritual growth. Our roots run deep in the red soil of Prince Edward Island, but our branches reach out to embrace the future.
          </p>
          <p class="text-on-surface-variant text-lg leading-relaxed italic border-l-4 border-secondary pl-5 mb-8">
            "To be a vibrant, welcoming community of faith that lives out God's love through service, sanctuary, and song."
          </p>
          <div class="flex gap-12">
            <div>
              <p class="font-headline text-3xl font-bold text-secondary">3</p>
              <p class="text-sm font-label uppercase tracking-widest text-outline mt-0.5">Communities</p>
            </div>
            <div>
              <p class="font-headline text-3xl font-bold text-secondary">150+</p>
              <p class="text-sm font-label uppercase tracking-widest text-outline mt-0.5">Years of Grace</p>
            </div>
          </div>
        </div>
        <div class="bg-surface-container rounded-xl p-8 border border-outline-variant">
          <div class="flex items-center gap-3 mb-6">
            <span class="material-symbols-outlined text-tertiary text-3xl select-none" aria-hidden="true">volunteer_activism</span>
            <h3 class="font-headline text-xl font-bold text-primary">All Are Welcome</h3>
          </div>
          <p class="text-on-surface-variant leading-relaxed">
            Whether you are a lifelong member, a curious visitor, or someone seeking community for the first time — our doors are open. Come as you are.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Churches -->
  <section class="py-20" aria-labelledby="churches-heading">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="text-secondary font-label font-bold tracking-[0.3em] uppercase block mb-3 text-sm">Our Congregations</span>
        <h2 id="churches-heading" class="font-headline text-4xl md:text-5xl text-primary font-bold">Three Churches, One Charge</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {churches.map((church) => (
          <a
            href={`/churches/${church.id}`}
            class="group block bg-surface-container-low border border-outline-variant rounded-xl p-6 hover:border-secondary hover:shadow-md transition-all duration-200"
          >
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-tertiary text-xl select-none" aria-hidden="true">church</span>
            </div>
            <h3 class="font-headline text-lg font-bold text-primary group-hover:text-secondary mb-2 transition-colors">{church.data.title}</h3>
            <p class="text-sm text-on-surface-variant mb-1 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-base text-outline select-none" aria-hidden="true">schedule</span>
              {church.data.serviceTime}
            </p>
            <p class="text-sm text-on-surface-variant flex items-center gap-1.5">
              <span class="material-symbols-outlined text-base text-outline select-none" aria-hidden="true">location_on</span>
              {church.data.address}
            </p>
            <p class="text-secondary text-sm font-semibold mt-4 group-hover:underline">View schedules →</p>
          </a>
        ))}
      </div>
    </div>
  </section>


</BaseLayout>
