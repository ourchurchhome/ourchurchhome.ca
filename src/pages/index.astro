---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import HeroWidget from '../components/widgets/HeroWidget.astro';
import NewsWidget from '../components/widgets/NewsWidget.astro';
import VisionWidget from '../components/widgets/VisionWidget.astro';
import ChurchesWidget from '../components/widgets/ChurchesWidget.astro';

const bannerEntries = await getCollection('banner');
const bannerEntry = bannerEntries[0];
const bannerEnabled = bannerEntry?.data.enabled ?? false;
const bannerLink = bannerEntry?.data.link ?? null;
const { Content: BannerContent } = bannerEntry ? await render(bannerEntry) : { Content: null };

// ── Homepage singleton ────────────────────────────────────────────────────────
const homepageEntries = await getCollection('homepage');
const homepage = homepageEntries[0];
const widgets = homepage?.data.widgets ?? [];
---

<BaseLayout title="Home" description="Mount Stewart, Morell, St. Peters Bay Pastoral Charge — ourchurchhome.ca">

  <!-- Banner -->
  {bannerEnabled && BannerContent && (
    bannerLink ? (
      <a
        href={bannerLink}
        class="group flex items-center justify-center gap-2 bg-secondary text-on-secondary px-6 py-3 text-center text-sm font-medium leading-snug hover:bg-secondary-container transition-colors duration-200 [&_p]:inline [&_strong]:font-bold"
      >
        <BannerContent />
        <span class="material-symbols-outlined text-base shrink-0 transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">arrow_forward</span>
      </a>
    ) : (
      <div class="flex items-center justify-center bg-secondary text-on-secondary px-6 py-3 text-center text-sm font-medium leading-snug [&_p]:inline [&_strong]:font-bold">
        <BannerContent />
      </div>
    )
  )}

  <!-- Page sections — rendered in the order defined by homepage.json widgets -->
  {widgets.map((widget) => {
    if (widget.type === 'hero')     return <HeroWidget     {...widget} />;
    if (widget.type === 'news')     return <NewsWidget     {...widget} />;
    if (widget.type === 'vision')   return <VisionWidget   {...widget} />;
    if (widget.type === 'churches') return <ChurchesWidget {...widget} />;
    return null;
  })}


</BaseLayout>
