# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/applications/new
# Homepage URL: http://localhost:4321
# Authorization callback URL: http://localhost:4321/cms/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The GitHub repo the CMS will read/write content from
GITHUB_REPO_OWNER=ourchurchhome
GITHUB_REPO_NAME=ourchurchhome.ca
# The branch to commit content changes to
GITHUB_REPO_BRANCH=main

# A random 64-char hex string used to sign session cookies
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Random 8-char string to invalidate ISR
# Generate with: node -e "console.log(require('crypto').randomBytes(4).toString('hex'))"
ISR_SECRET=e4a74472

# Set to "local" to use the local filesystem backend (no GitHub credentials required)
CMS_PERSISTENCE=github